# Copy this file to /srv/projectai-staging/.env.auth-staging on the Staging
# server, fill every required value there, and set its mode to 600.
# Never commit the real file or pass its contents through deployment logs.

# PostgreSQL container and application connection (use projectai-postgres as host).
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# Better Auth endpoint includes the Staging basePath and /api/auth.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
AUTH_COOKIE_PREFIX=
AUTH_TRUSTED_ORIGINS=

# Private Staging MinIO administrator. Do not reuse these values for the app.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Bucket-scoped application identity and fixed non-public Staging endpoint.
OBJECT_STORAGE_ENDPOINT=http://projectai-minio:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=projectai-staging-files
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_USE_SSL=false
MAX_UPLOAD_BYTES=52428800
UPLOAD_ALLOWED_EXTENSIONS=pdf,docx,xlsx,pptx,txt,md

# Shared application/Worker processing contract.
DOCUMENT_WORKER_POLL_MS=2000
DOCUMENT_WORKER_LEASE_SECONDS=120
DOCUMENT_WORKER_MAX_ATTEMPTS=3
DOCUMENT_MAX_PAGES=1000
DOCUMENT_MAX_SLIDES=1000
DOCUMENT_MAX_SHEETS=100
DOCUMENT_MAX_ROWS=100000
DOCUMENT_MAX_COLUMNS=1000
DOCUMENT_MAX_CELLS=500000
DOCUMENT_MAX_CHARACTERS=10000000
DOCUMENT_MAX_SECTIONS=20000
DOCUMENT_MAX_CHUNKS=50000
DOCUMENT_PARSE_TIMEOUT_MS=120000
DOCUMENT_CHUNK_TARGET_CHARS=1800
DOCUMENT_CHUNK_OVERLAP_CHARS=200
DOCUMENT_CHUNK_MIN_CHARS=120
DOCUMENT_PARSER_VERSION=1
DOCUMENT_CHUNKER_VERSION=1

# Embedding queue configuration. The Qwen Base URL and Secret File stay in
# the separately protected .env.ai / Compose Secret boundary.
AI_EMBEDDING_ENABLED=false
AI_EMBEDDING_PROFILE_ID=qwen-text-embedding-cn-v1
AI_EMBEDDING_DIMENSIONS=1024
AI_EMBEDDING_WORKER_POLL_MS=2000
AI_EMBEDDING_WORKER_LEASE_SECONDS=120
AI_EMBEDDING_WORKER_MAX_ATTEMPTS=3
AI_EMBEDDING_BATCH_SIZE=10
AI_EMBEDDING_BATCH_MAX_CHARACTERS=30000
AI_EMBEDDING_DAILY_JOB_LIMIT=500
AI_EMBEDDING_DAILY_TOKEN_LIMIT=5000000

# Insert-only Staging seed identities. Passwords must be strong and unique.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_MANAGER_A_EMAIL=
SEED_MANAGER_A_PASSWORD=
SEED_MANAGER_B_EMAIL=
SEED_MANAGER_B_PASSWORD=
SEED_MEMBER_A_EMAIL=
SEED_MEMBER_A_PASSWORD=
SEED_VIEWER_A_EMAIL=
SEED_VIEWER_A_PASSWORD=
