# Copy this file to /srv/projectai-staging/.env.auth-staging on the Staging
# server, fill every required value there, and set its mode to 600.
# Never commit the real file or pass its contents through deployment logs.

# PostgreSQL container and application connection (use projectai-postgres as host).
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# Better Auth endpoint includes the Staging basePath and /api/auth.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
AUTH_COOKIE_PREFIX=
AUTH_TRUSTED_ORIGINS=

# Private Staging MinIO administrator. Do not reuse these values for the app.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Bucket-scoped application identity and fixed non-public Staging endpoint.
OBJECT_STORAGE_ENDPOINT=http://projectai-minio:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=projectai-staging-files
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_USE_SSL=false
MAX_UPLOAD_BYTES=52428800
UPLOAD_ALLOWED_EXTENSIONS=pdf,docx,xlsx,pptx,txt,md

# Insert-only Staging seed identities. Passwords must be strong and unique.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_MANAGER_A_EMAIL=
SEED_MANAGER_A_PASSWORD=
SEED_MANAGER_B_EMAIL=
SEED_MANAGER_B_PASSWORD=
SEED_MEMBER_A_EMAIL=
SEED_MEMBER_A_PASSWORD=
SEED_VIEWER_A_EMAIL=
SEED_VIEWER_A_PASSWORD=
