{
  "name": "project-ai-os",
  "version": "0.5.0-staging",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test --test-concurrency=1 tests/rendered-html.test.mjs tests/proxy-redirect.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:artifacts": "node --test --test-concurrency=1 tests/artifact-sanitizer.test.mjs tests/review-manifest.test.mjs",
    "test:deployment": "node --test tests/deployment-contract.test.mjs",
    "review:sanitize": "node scripts/sanitize-test-artifacts.mjs",
    "review:finalize": "node scripts/finalize-review-manifest.mjs",
    "qa:mvp": "npm run typecheck && npm run lint && npm test && npm run test:integration && npm run test:documents && npm run test:storage && npm run test:document-integration && npm run test:artifacts && npm run test:deployment && npm run test:e2e",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern playwright-report --ignore-pattern review-artifacts --ignore-pattern product-review-evidence --ignore-pattern test-results --ignore-pattern test-logs",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db/migrate.ts",
    "db:seed": "tsx scripts/db/seed.ts",
    "db:reset:test": "NODE_ENV=test tsx scripts/db/reset-test.ts && npm run db:seed",
    "test:integration": "node --import tsx --test --test-concurrency=1 tests/integration/identity-project-isolation.test.ts tests/integration/review-project-permissions.test.ts",
    "test:document-integration": "node --import tsx --test --test-concurrency=1 tests/integration/document-processing.test.ts",
    "test:files": "node --import tsx --test --test-concurrency=1 tests/file-validation.test.ts tests/direct-upstream-fetch.test.ts",
    "test:documents": "node --import tsx --test --test-concurrency=1 tests/document-processing.test.ts",
    "test:storage": "npm run test:files && node --import tsx --test --test-concurrency=1 tests/integration/project-files.test.ts",
    "storage:verify": "tsx scripts/storage-verify.ts",
    "storage:reconcile": "tsx scripts/reconcile-file-storage.ts",
    "storage:smoke": "tsx scripts/verify-file-storage-flow.ts",
    "documents:smoke": "tsx scripts/verify-document-processing-flow.ts",
    "documents:lease-smoke": "tsx scripts/verify-document-worker-lease.ts",
    "worker:documents": "tsx scripts/document-worker.ts",
    "worker:documents:once": "tsx scripts/document-worker.ts --once",
    "documents:enqueue": "tsx scripts/enqueue-document-ingestion.ts",
    "test:cleanup": "tsx scripts/cleanup-ci-test-data.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1087.0",
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.6.23",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "fast-xml-parser": "5.10.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "pdfjs-dist": "6.1.200",
    "pg": "^8.22.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.81.0",
    "tailwind-merge": "^3.6.0",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@cloudflare/workers-types": "5.20260713.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/yauzl": "^3.4.0",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "overrides": {
    "postcss": "8.5.18"
  },
  "type": "module"
}
