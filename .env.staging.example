NODE_ENV=production
PORT=3000

NEXT_PUBLIC_BASE_PATH=/tool/projectai-staging
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_APP_VERSION=0.4.0-staging
NEXT_PUBLIC_COMMIT_SHA=
NEXT_PUBLIC_BUILD_TIME=

AI_PROVIDER=mock

# Use the restricted .env.auth-staging file on the server for these values.
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://gridworks.cn/tool/projectai-staging/api/auth
AUTH_COOKIE_PREFIX=projectai_staging
AUTH_TRUSTED_ORIGINS=https://gridworks.cn

# Staging-only private MinIO. Root credentials are used only by MinIO and its
# controlled initialization/backup tasks; the application receives the
# separate bucket-scoped OBJECT_STORAGE identity.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
OBJECT_STORAGE_ENDPOINT=http://projectai-minio:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=projectai-staging-files
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_USE_SSL=false

MAX_UPLOAD_BYTES=52428800
UPLOAD_ALLOWED_EXTENSIONS=pdf,docx,xlsx,pptx,txt,md
