NODE_ENV=production
PORT=3000
NEXT_PUBLIC_BASE_PATH=/tool/projectai
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_VERSION=0.8.0-staging
NEXT_PUBLIC_COMMIT_SHA=
NEXT_PUBLIC_BUILD_TIME=

# Project-manager daily report MVP. Keep both disabled unless the environment
# has applied Migrations 0016 and 0017 and completed the acceptance checklist.
PM_DAILY_REPORT_ENABLED=false
WECOM_TIMESHEET_SYNC_ENABLED=false
PM_DAILY_REPORT_CONFIDENCE_THRESHOLD=0.85

AI_ASSISTANT_ENABLED=false
AI_PROVIDER=qwen
AI_REGION=cn-beijing
AI_PROJECT_ASSISTANT_PROFILE_ID=qwen-project-assistant-cn-v1
AI_EXECUTION_STALE_AFTER_MS=900000
AI_ASSISTANT_RETRIEVAL_MODE=lexical
AI_HYBRID_RETRIEVAL_PROFILE_ID=hybrid-rrf-v1
AI_HYBRID_QUERY_EMBEDDING_TIMEOUT_MS=5000
AI_HYBRID_VECTOR_SQL_TIMEOUT_MS=1500
AI_HYBRID_QUERY_EMBEDDING_DAILY_TOKEN_LIMIT=5000000
# Production remains disabled and must not receive QWEN_BASE_URL or a Qwen Secret.
# B3-B2 remains Staging-only. Production must keep retrieval mode lexical and
# must not run Migration 0007 or query-embedding calls.

# B3-B1 remains Staging-only. Production must keep this disabled and must not
# run the pgvector migration or an Embedding Worker.
AI_EMBEDDING_ENABLED=false
AI_EMBEDDING_PROFILE_ID=qwen-text-embedding-cn-v1
AI_EMBEDDING_DIMENSIONS=1024
AI_EMBEDDING_WORKER_POLL_MS=2000
AI_EMBEDDING_WORKER_LEASE_SECONDS=120
AI_EMBEDDING_WORKER_MAX_ATTEMPTS=3
AI_EMBEDDING_BATCH_SIZE=10
AI_EMBEDDING_BATCH_MAX_CHARACTERS=30000
AI_EMBEDDING_DAILY_JOB_LIMIT=500
AI_EMBEDDING_DAILY_TOKEN_LIMIT=5000000
AI_EMBEDDING_WORKER_SHUTDOWN_DRAIN_MS=25000

DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://gridworks.cn/tool/projectai/api/auth
AUTH_COOKIE_PREFIX=projectai_production
AUTH_TRUSTED_ORIGINS=https://gridworks.cn
AUTH_PROVIDER=wecom
ALLOW_MOCK_WECOM_AUTH=false
ALLOW_LEGACY_CREDENTIAL_TEST_AUTH=false
ORGANIZATION_NAME=Kivisense

# Formal WeCom QR authentication boundary. The callback adapter remains
# disabled until the real corporate WeCom application credentials and API are
# supplied; never enable Mock WeCom authentication in Production.
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_AUTH_CALLBACK_URL=
WECOM_AUTH_SECRET_FILE=/run/secrets/wecom_auth_secret

# S3-compatible project file storage. Keep credentials server-side only.
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_USE_SSL=true

MAX_UPLOAD_BYTES=52428800
UPLOAD_ALLOWED_EXTENSIONS=pdf,docx,xlsx,pptx,txt,md

# Asynchronous lexical document processing. Keep these values identical
# between the application and the independent document Worker.
DOCUMENT_WORKER_POLL_MS=2000
DOCUMENT_WORKER_LEASE_SECONDS=120
DOCUMENT_WORKER_MAX_ATTEMPTS=3
DOCUMENT_MAX_PAGES=1000
DOCUMENT_MAX_SLIDES=1000
DOCUMENT_MAX_SHEETS=100
DOCUMENT_MAX_ROWS=100000
DOCUMENT_MAX_COLUMNS=1000
DOCUMENT_MAX_CELLS=500000
DOCUMENT_MAX_CHARACTERS=10000000
DOCUMENT_MAX_SECTIONS=20000
DOCUMENT_MAX_CHUNKS=50000
DOCUMENT_PARSE_TIMEOUT_MS=120000
DOCUMENT_CHUNK_TARGET_CHARS=1800
DOCUMENT_CHUNK_OVERLAP_CHARS=200
DOCUMENT_CHUNK_MIN_CHARS=120
DOCUMENT_PARSER_VERSION=1
DOCUMENT_CHUNKER_VERSION=1
